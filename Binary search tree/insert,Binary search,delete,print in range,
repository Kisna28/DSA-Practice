import java.util.*
data class Node(
    var data: Int,
    var left: Node? = null,
    var right: Node? = null
) 

fun insert(root:Node?,data:Int):Node{
    var root = root
    if(root == null){
        root = Node(data)
       return root
    }
    
    if(root.data > data){
        // left subtree
      root.left = insert(root.left,data)
    }
     if(root.data < data){
       // right subtree
      root.right = insert(root.right,data)
    }
     
    return root
}

//Search in BST 
fun search(root:Node?,key:Int):Boolean{ // O(H)
    if(root == null){return false}
    
    if(root.data == key){return true}
    
  
    if(root.data > key){
        return search(root.left,key)
    }else{
        return search(root.right,key)
    }
}

//Delet a Node -> adobe  // IMP

fun delete(root:Node?,`val`:Int):Node?{
      if (root == null) return null
    if(root.data < `val`){
        root?.right = delete(root?.right,`val`)
    }else if(root.data > `val`){
        root?.left = delete(root?.left,`val`)
    }else{
       	// voila 
        //case 1 - leaf node
        
        if(root.left == null && root.right == null){
            return null
        }
        
        //case 2 : single child
        
        if(root.left ==null){
            return root.right
        }else if( root.right == null){
            return root.left
        }
        //case 3 both child - find inorderSuccseor(left most node in right tree)
        val successor  = findInorderSuccessor(root.right!!)
        println("root.data = ${root.data}")
        println("root.right = ${root.right}")
        
        root.data = successor.data
        
        root.right = delete(root.right,successor.data)
    }
    
    return root
}

fun findInorderSuccessor(root:Node):Node{
    var current = root
    while(current.left !=null){
        current = current.left!!
    }
    println("current = $current")
    return current
}

fun findRange(root:Node?,k1:Int,k2:Int){
    if(root == null){return}
    
    if (root.data >= k1 && root.data <= k2) { // or  if(root.data in k1..k2){
       findRange(root.left,k1,k2) 
       print("${root.data} ")
       findRange(root.right,k1,k2) 
    }else if( root.data < k1){
      findRange(root.left,k1,k2)  
    }else{
        findRange(root.right,k1,k2)
    }
    
}

// Root to path - snapdeal,fb,amezon 
fun root2path(root:Node?,path:ArrayList<Int>){
    if(root == null){return}
    
    path.add(root.data)
    
    if(root.left == null && root.right == null){
        printPath(path)
    }
    
    root2path(root.left,path)
    root2path(root.right,path)
    
    path.remove(path.size-1)
}
 fun printPath(path: ArrayList<Int>){
     for(i in 0 until path.size){
         print("${path.get(i)} -> ")
     }
     println("null")
 }


fun inorder(root:Node?){
    if(root == null){return}
    inorder(root.left) 
    print("${root.data} ") 
    inorder(root.right) 
}

