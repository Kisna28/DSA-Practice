// Root to path - snapdeal,fb,amezon 
fun root2path(root:Node?,path:ArrayList<Int>){
    if(root == null){return}
    
    path.add(root.data)
    
    if(root.left == null && root.right == null){
        printPath(path)
    }
    
    root2path(root.left,path)
    root2path(root.right,path)
    
    path.removeAt(path.size-1)
}
 fun printPath(path: ArrayList<Int>){
     for(i in 0 until path.size){
         print("${path.get(i)} -> ")
     }
     println("null")
 }
 
 fun isValidBST(root:Node?,min:Node?,max:Node?):Boolean{
     if(root == null){return true}
 
 	if(min !=null && root.data <= min.data){
        return false
    }
    else if(max !=null && root.data >= max.data){
        return false
    }
    else{
        return isValidBST(root.left,min,root) &&
        isValidBST(root.right,root,max)
    }
 }
 
 fun createMirror(root:Node?):Node?{ //O(n)
     if(root == null){return null}
     val lm = createMirror(root.left)
     val rm = createMirror(root.right)
     
     root.left = rm
     root.right = lm
     return root
     
 }
 
 //required sorted array
 fun creatBSTFromArray(arr:ArrayList<Int>,start:Int,end:Int):Node?{ //O(n)
     if(start > end){return null}
     
     val mid = (start+end)/2
     
     val root = Node(arr[mid])
     
     root.left = creatBSTFromArray(arr,start,mid-1)
     root.right = creatBSTFromArray(arr,mid+1,end)
     return root
 }
 fun balanceBST(root: Node?): Node? {
    val inorder = ArrayList<Int>()

    getInorder(root, inorder)
    
    return creatBSTFromArray(inorder, 0, inorder.size - 1)
}
 
 fun getInorder(root:Node?,inorder:ArrayList<Int>){
     if(root == null){return}
     getInorder(root.left,inorder)
     inorder.add(root.data)
     getInorder(root.right,inorder)
      }

fun height(root: Node?): Int {
    if (root == null) return 0

    val leftHeight = height(root.left)
    val rightHeight = height(root.right)

    return maxOf(leftHeight, rightHeight) + 1
}

var maxBST = 0

data class Info(
	val isBST:Boolean,
    val size:Int,
    val min:Int,
    val max:Int,
)

fun largestBST(root:Node?):Info{
    if(root == null){return Info(true,0,Int.MAX_VALUE,Int.MIN_VALUE)}
    //LI = leftInfo and RI = righr Info
    val LI = largestBST(root.left)
    val RI = largestBST(root.right)
    
    val size = LI.size + RI.size + 1
    val min = minOf(root.data,minOf(LI.min,RI.min))
    val max = maxOf(root.data,maxOf(LI.max,RI.max))
    
    if(root.data <= LI.max || root.data >= RI.min){
        return Info(false,size,min,max)
    }
    if(LI.isBST && RI.isBST){
        maxBST = maxOf(maxBST, size)
        return Info(true,size,min,max)
    }
    return Info(false,size,min,max)
}
// Best case: O(h) where h is the height of the BST.
// Worst case (all nodes fall in range or skewed tree): O(n).
fun rangeSum(root:Node?,L:Int,R:Int):Int{
    if(root == null){return 0}
    
    if(root.data < L){
        return rangeSum(root.right, L, R)
    }
    if(root.data > R){
        return rangeSum(root.left, L, R)
    }
    
    return root.data +
            rangeSum(root.left, L, R) +
            rangeSum(root.right, L, R)
    
}
fun cloestElement(root:Node?,k:Int, closest: Int):Int{
    if (root == null) {return closest}

    var newClosest = closest
    
     if (Math.abs(root.data - k) < Math.abs(closest - k)) {
        newClosest = root.data
    }

     return if (k < root.data) {
        cloestElement(root.left, k, newClosest)
    } else if (k > root.data) {
        cloestElement(root.right, k, newClosest)
    } else {
        root.data
    }
   }

// Time Complexity: O(n)
// Space Complexity: O(h) (recursion stack, where h is tree height).
var count = 0

fun kthsmallestElement(root: Node?, k: Int): Int {
    if (root == null) return -1

    val left = kthsmallestElement(root.left, k)
    if (left != -1) return left

    count++
    if (count == k) return root.data

    return kthsmallestElement(root.right, k)
}

fun inorderSet(root: Node?, set: HashSet<Int>) {
    if (root == null) return

    inorderSet(root.left, set)
    set.add(root.data)
    inorderSet(root.right, set)
}

fun printPairs(root: Node?, target: Int, set: HashSet<Int>) {
  if (root == null) return

    printPairs(root.left, target, set)

    val complement = target - root.data

    if (set.contains(complement)) {
        println("($complement, ${root.data})")
    }

    printPairs(root.right, target, set)
}

