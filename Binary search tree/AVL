var root: Node? = null

    root = insert(root, 10)
    root = insert(root, 20)
    root = insert(root, 30)
    root = insert(root, 40)
    root = insert(root, 50)
    root = insert(root, 25)

    inorder(root)
    println("\nPreOrder")
    preOrder(root)
    
    deleteNode(root,25)
    println("\n Inorder after Delete:")
