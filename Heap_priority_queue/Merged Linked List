class Node(var data: Int) {
    var next: Node? = null
}
fun buildList(arr: IntArray): Node? {
    if (arr.isEmpty()) return null

    val head = Node(arr[0])
    var curr = head

    for (i in 1 until arr.size) {
        curr.next = Node(arr[i])
        curr = curr.next!!
    }

    return head
}
fun printList(head: Node?) {
    var curr = head

    while (curr != null) {
        print(curr.data)
        if (curr.next != null) print(" -> ")
        curr = curr.next
    }
    println()
}
fun mergeKLists(lists: Array<Node?>): Node? {
val pq = PriorityQueue<Node> { a, b -> a.data - b.data }
  for(head in lists){
      if(head!=null){
          pq.offer(head)
      }
  }
  val dummy = Node(-1)
  var tail = dummy
    
    while(pq.isNotEmpty()){
        val smallest = pq.poll()
         tail.next = smallest
        tail = tail.next!!

        if (smallest.next != null) {
            pq.offer(smallest.next)
        }
    }
    
    return dummy.next
}
fun main() {

 val list1 = buildList(intArrayOf(1, 3, 7))
    val list2 = buildList(intArrayOf(2, 4, 8))
    val list3 = buildList(intArrayOf(9, 10, 11))

    val lists = arrayOf(list1, list2, list3)

    val ans = mergeKLists(lists)

    print("Merged List: ")
    printList(ans)
    
}
