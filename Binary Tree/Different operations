    fun <T> heightOfTree(root: Node<T>?): Int { // O(n) and space : O(h)
    if (root == null) return 0

    val leftHeight = heightOfTree(root.left)
    val rightHeight = heightOfTree(root.right)

    return maxOf(leftHeight, rightHeight) + 1
}
    fun countNodes(root: Node<T>?):Int { // O(n) and space : O(h)
        if (root == null) return 0
        val leftCount = countNodes(root.left)
        val rightCount = countNodes(root.right)
        return leftCount + rightCount + 1
}
       fun sumOfNodes(root: Node<Int>?):Int {// O(n)
        if (root == null) return 0
        val leftSum = sumOfNodes(root.left)
        val rightSum = sumOfNodes(root.right)
        return leftSum + rightSum + root.data
}
        fun <T> diameter2(root: Node<T>?): Int {// O(n^2)
        if (root == null) return 0
        val leftheight = heightOfTree<T>(root.left)
        val leftDiam = diameter2(root.left)
        val righthright = heightOfTree<T>(root.right)
        val rightDiam = diameter2(root.right)
        val selfDiam =  leftheight + righthright + 1
            return maxOf(leftDiam,rightDiam,selfDiam)
}
        data class Info(
        val diam:Int ,
        val ht:Int        
        )
         fun <T> diameter(root: Node<T>?): Info {// O(n^2)
        if (root == null) {return Info(0,0)}
        val leftInfo:Info = diameter(root.left)
        val rightInfo:Info = diameter(root.right)
        val diam = maxOf(maxOf(leftInfo.diam , rightInfo.diam), (leftInfo.ht+rightInfo.ht+1))
        val ht =  maxOf(leftInfo.ht , rightInfo.ht)+1
            return Info(diam,ht)
}
