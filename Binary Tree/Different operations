 fun  check(node: Node<T>?, value: T): Boolean {
    if (node == null) return true

    if (node.data != value) return false

    return check(node.left, value) &&
           check(node.right, value)
}
 
 fun invert(root: Node<T>?):Node<T>?{
     if(root == null){return null}
     
     //swap
     val temp = root.left
     root.left = root.right
     root.right = temp
     
     //recursive call
     invert(root.left)
     invert(root.right)
     
     return root
 }
 fun deleteLeaf(root: Node<Int>?,x:Int):Node<Int>?{
         if(root == null){return null}
         
         root.left = deleteLeaf(root.left, x)
         root.right = deleteLeaf(root.right,x)
      
         if(root.left == null && root.right == null && root.data == x ){
             return null
         }
         return root
}
 fun findDuplicate(root: Node<Int>?): List<Node<Int>> {

    val map = HashMap<String, Int>()
    val ans = ArrayList<Node<Int>>()
    serialize(root, map, ans)

    return ans
}
 
 
fun serialize(
    root: Node<Int>?,
    map: HashMap<String, Int>,
    ans: ArrayList<Node<Int>>
): String {

    if(root == null) return "#"

    val left = serialize(root.left, map, ans)
    val right = serialize(root.right, map, ans)

    val str = "${root.data},$left,$right"

    map[str] = map.getOrDefault(str, 0) + 1

    if(map[str] == 2){
        ans.add(root)
    }

    return str
}

var maxSum = Int.MIN_VALUE
fun maxPathSum(root: Node<Int>?): Int {
        gain(root)
        return maxSum
    }
private fun gain(node: Node<Int>?): Int {
        if (node == null) return 0

        // ignore negative paths
        val left = maxOf(0, gain(node.left))
        val right = maxOf(0, gain(node.right))

        // path THROUGH current node
        val currentSum = node.data + left + right

        maxSum = maxOf(maxSum, currentSum)

        // return BEST single path for parent
        return node.data + maxOf(left, right)
    }
}
