 fun transform(root: Node<Int>?): Int {

    if (root == null) {
        return 0
    }

    val leftChild = transform(root.left)
    val rightChild = transform(root.right)

    val old = root.data

    val leftData = root.left?.data ?: 0
    val rightData = root.right?.data ?: 0

    root.data = leftData + leftChild + rightData + rightChild

    return old
}
 fun minDisct(root: Node<Int>?,n1:Int,n2:Int):Int{
     val lca = lca2(root,n1,n2)
    val dist1 = lcaDist(lca,n1)
    val dist2 = lcaDist(lca,n2)
    
    return dist1+dist2
 }
 fun lcaDist(root: Node<Int>?,n:Int):Int{
     if(root==null){return -1}
     if(root?.data == n){return 0}
     val leftDist = lcaDist(root.left,n)
     val rightDist = lcaDist(root.right,n)
     
     if(leftDist == -1 && rightDist == -1){
         return -1
     }else if(leftDist == -1){
         return rightDist+1
     }else{
         return leftDist+1
     }
 }
