   fun <T> lca2(root: Node<T>?, n1: T, n2: T): Node<T>? {

    // base case
    if (root == null) return null

    // if current node matches
    if (root.data == n1 || root.data == n2) {
        return root
    }

    // search in left subtree
    val leftLca = lca2(root.left, n1, n2)

    // search in right subtree
    val rightLca = lca2(root.right, n1, n2)

    // if found in both sides
    if (leftLca != null && rightLca != null) {
        return root
    }

    // if found only on one side
    return leftLca ?: rightLca
}
   
