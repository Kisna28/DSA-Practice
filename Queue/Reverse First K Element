import java.util.*
fun main() {
   val k = 5
     val queue: Queue<Int> = ArrayDeque()
     val queueINPlace: Queue<Int> = ArrayDeque()
     val queueRecursion: Queue<Int> = ArrayDeque()
     for(i in 1..10){
         queue.add(i)
         queueINPlace.add(i)
         queueRecursion.add(i)
     }
     ReverseFirstKElement(k,queue)
     ReverseFirstKElementINPlace(k,queueINPlace)
     ReverseFirstKElementRecursion(k,queueRecursion)
}

// NOTE : Always Use the IN Place Approch

fun ReverseFirstKElementRecursion(k: Int, queue: Queue<Int>) { //time :  O(n)  space: O(k)
    if (k <= 0) return
    val front = queue.remove()
    ReverseFirstKElementRecursion(k-1,queue)
    queue.add(front)
    // reverser required
   println("queue Recursion = $queue")

}
fun ReverseFirstKElementINPlace(k: Int, queue: Queue<Int>) {
    if (k <= 0 || k > queue.size) return

    val stack = Stack<Int>()
    val size = queue.size

    // Step 1
    for (i in 0 until k) {
        stack.push(queue.remove())
    }

    // Step 2
    while (stack.isNotEmpty()) {
        queue.add(stack.pop())
    }
     println("queue= $queue")
     println("size - k = ${size-k}")

    // Step 3
    for (i in 0 until size - k) {
        queue.add(queue.remove())
    }
    println("queue In Place = $queue")
}

fun ReverseFirstKElement(k:Int, queue:Queue<Int>){ // TM : o(n)
    val q:Queue<Int> = ArrayDeque()
    val stack = Stack<Int>()
    for(i in 0 until k){
        stack.push(queue.remove())
    }
    while(!stack.isEmpty()){
        q.offer(stack.pop())
    }
    while(!queue.isEmpty()){
        q.offer(queue.remove())
    }
    println("queue = $q")
}
