import java.util.*
fun main() {
    val q: Queue<Int> = LinkedList<Int>()
    for(i in 1..10){
        q.add(i)
    }
    interLeave(q)
    println(q)
}
fun interLeave(q: Queue<Int>){
    val firstHalf: Queue<Int> = LinkedList<Int>()
    val size = q.size
    for(i in 0 until size/2){
        firstHalf.add(q.remove())
    }
    while(!firstHalf.isEmpty()){
        q.add(firstHalf.remove())
        q.add(q.remove())
    }
}
